
<div class="vh-100 d-flex justify-content-center align-items-center" style="background-color: #FAF9F6;">
   <div class "card shadow" style="background:rgba(255,255,255,0.8); min-width: 500px; max-width: 600px; min-height: 400px; padding:30px;">
<h2 class="text-center mb-4">Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
 <div id="error-messages" class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= render "devise/shared/error_messages", resource: resource %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>

  <div class="mb-3">
    <%= f.label :email,class:"form-label" %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email",class:"form-control" %>
  </div>

  <div class="d-grid">
    <%= f.submit "Send me reset password instructions",class:"btn btn-dark" %>
  </div>
<% end %>

<div class='mt-3 danger text-white'>
<%= render "devise/shared/links" %>
</div>
</div>
</div>