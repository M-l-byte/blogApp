<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="text-center mb-4">✍️ New Post</h1>

          <%= form_with model: @post, local: true do |form| %>
            <% if @post.errors.any? %>
              <div class="alert alert-danger">
                <h5><%= pluralize(@post.errors.count, "error") %> prevented this post from being saved:</h5>
                <ul>
                  <% @post.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :title, class: "form-label" %>
              <%= form.text_field :title, class: "form-control", placeholder: "Enter your post title" %>
            </div>

            <div class="mb-3">
              <%= form.label :body, class: "form-label" %>
              <%= form.text_area :body, class: "form-control", rows: 6, placeholder: "Write your content here..." %>
            </div>

            <div class="d-grid">
              <%= form.submit "Create Post", class: "btn btn-success" %>
            </div>
          <% end %>

          <div class="text-center mt-3">
            <%= link_to "⬅ Back to Posts", posts_path, class: "btn btn-outline-secondary btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
